{
  "name": "@lion5/component-library-gridstack",
  "version": "0.30.1",
  "type": "commonjs",
  "license": "MIT",
  "contributors": [
    "Michael Götz <michael.goetz@lion5.io> (https://github.com/michigg)",
    "Christopher Nagy <christopher.nagy@lion5.io> (https://github.com/nagychris)"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lion5/component-library"
  },
  "keywords": [
    "vue3",
    "vuejs",
    "vite",
    "typescript",
    "ui",
    "library"
  ],
  "scripts": {
    "build": "vite build",
    "test:unit": "cross-env TZ=UTC vitest --config ./vitest.unit.config.ts run",
    "test:unit:ui": "cross-env TZ=UTC vitest --ui --config ./vitest.unit.config.ts",
    "test:storybook": "cross-env TZ=UTC vitest --config ./vitest.config.ts run",
    "type-check": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "docs": "storybook dev -p 6006",
    "docs:build": "storybook build -o ../storybook-host/storybook-static/gridstack",
    "package-check": "publint",
    "package-type-check": "attw --pack . --exclude-entrypoints ./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./dist/index.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/index.css"
  ],
  "dependencies": {
    "@lion5/component-library": "0.30.1",
    "@turf/boolean-point-in-polygon": ">=7.3.4",
    "gridstack": ">=12.6.0",
    "lodash-es": ">=4.18.1",
    "remove": "^0.1.5",
    "vee-validate": ">=4.15.1",
    "vue": ">=3.5.32"
  },
  "peerDependencies": {
    "@lion5/component-library": ">= 0.12.1",
    "@turf/boolean-point-in-polygon": ">= 6.5.0 < 7",
    "lodash-es": ">=4.17.21",
    "gridstack": ">= 10.1.2 < 11",
    "vee-validate": ">=4.12.6",
    "vue": ">= 3.4.21"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@tsconfig/node22": "^22.0.5",
    "@types/dom-screen-wake-lock": "^1.0.3",
    "@types/jsdom": "^28.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/eslint-plugin": "^1.6.15",
    "@vitest/ui": "^4.1.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "sass-embedded": "^1.99.0",
    "storybook": "^10.3.5",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "gitHead": "4b5b01f298040c7d4206a67ab76b1b02fe7fe91e",
  "overrides": {
    "storybook": "$storybook"
  }
}
