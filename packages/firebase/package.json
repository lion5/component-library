{
  "name": "@lion5/component-library-firebase",
  "version": "0.30.1",
  "type": "module",
  "license": "MIT",
  "contributors": [
    "Michael Götz <michael.goetz@lion5.io> (https://github.com/michigg)",
    "Christopher Nagy <christopher.nagy@lion5.io> (https://github.com/nagychris)"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lion5/component-library"
  },
  "keywords": [
    "vue3",
    "vuejs",
    "vite",
    "typescript",
    "ui",
    "library"
  ],
  "scripts": {
    "build": "vite build",
    "test:unit": "cross-env TZ=UTC vitest --project unit run",
    "test:unit:ui": "cross-env TZ=UTC vitest --ui --project unit",
    "test:storybook": "cross-env TZ=UTC vitest --project storybook run",
    "test:all": "cross-env TZ=UTC vitest run",
    "type-check": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "docs": "storybook dev -p 6006",
    "docs:build": "storybook build -o ../storybook-host/storybook-static/firebase",
    "package-check": "publint",
    "package-type-check": "attw --pack . --exclude-entrypoints ./dist/index.css --ignore-rules cjs-resolves-to-esm"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/index.css"
  ],
  "dependencies": {
    "@lion5/component-library": "0.30.1",
    "firebase": "^12.12.0",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "@lion5/component-library": ">= 0.12.1",
    "firebase": ">= 9.23.0 < 10",
    "vue": ">= 3.4.21"
  },
  "devDependencies": {},
  "gitHead": "4b5b01f298040c7d4206a67ab76b1b02fe7fe91e"
}
