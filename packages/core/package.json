{
  "name": "@lion5/component-library",
  "version": "0.30.3",
  "type": "module",
  "license": "MIT",
  "contributors": [
    "Michael Götz <michael.goetz@lion5.io> (https://github.com/michigg)",
    "Christopher Nagy <christopher.nagy@lion5.io> (https://github.com/nagychris)"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lion5/component-library"
  },
  "keywords": [
    "vue3",
    "vuejs",
    "vite",
    "typescript",
    "ui",
    "library"
  ],
  "scripts": {
    "build": "vite build",
    "test:unit": "cross-env TZ=UTC vitest --project unit run",
    "test:unit:ui": "cross-env TZ=UTC vitest --ui --project unit",
    "test:storybook": "cross-env TZ=UTC vitest --project storybook run",
    "test:all": "cross-env TZ=UTC vitest run",
    "type-check": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "docs": "storybook dev -p 6006",
    "docs:build": "storybook build -o ../storybook-host/storybook-static/core",
    "package-check": "publint",
    "package-type-check": "attw --pack . --exclude-entrypoints ./dist/index.css --ignore-rules cjs-resolves-to-esm"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/index.css"
  ],
  "dependencies": {
    "@oddbird/css-anchor-positioning": "^0.9.0",
    "@oddbird/popover-polyfill": "^0.6.1",
    "@vueuse/core": ">=14.2.1",
    "bootstrap-icons": ">=1.13.1",
    "lodash-es": ">=4.18.1",
    "pinia": ">=3.0.4",
    "remove": "^0.1.5",
    "vee-validate": ">=4.15.1",
    "vue": ">=3.5.32",
    "vue-multiselect": ">=3.5.0",
    "vue-router": ">=5.0.4",
    "yup": ">=1.7.1"
  },
  "peerDependencies": {
    "@vueuse/core": ">=11.1.0",
    "bootstrap-icons": ">=1.11.3",
    "lodash-es": ">=4.17.21",
    "pinia": ">=2.1.7",
    "vee-validate": ">=4.14.7",
    "vue": ">=3.4.21",
    "vue-router": ">=4.3.0",
    "yup": ">=1.4.0"
  },
  "devDependencies": {},
  "gitHead": "4b5b01f298040c7d4206a67ab76b1b02fe7fe91e"
}
